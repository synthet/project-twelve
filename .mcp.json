{
  "_comment": "Project MCP servers for Claude Code. Copy templates into mcpServers and set env vars. Secrets via env only.",
  "_unityMcpTemplate": {
    "project-twelve-unity-mcp": {
      "command": "RELAY_PATH",
      "args": ["--mcp"],
      "env": {
        "UNITY_PROJECT_PATH": "ABSOLUTE_PATH_TO_THIS_REPO"
      }
    }
  },
  "_githubMcpTemplate": {
    "project-twelve-github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  },
  "_subagentOrchestratorNote": "Optional sibling repo MCP for external CLI reviews. See docs/EXTERNAL_CLI_REVIEWS.md. Project key: project-twelve-subagent-orchestrator",
  "_fffMcpTemplate": {
    "project-twelve-fff-mcp": {
      "type": "stdio",
      "command": "fff-mcp",
      "args": ["--no-warmup", "ABSOLUTE_PATH_TO_THIS_REPO"]
    }
  },
  "mcpServers": {
    "project-twelve-unity-mcp": {
      "command": "C:\\Users\\dmnsy\\.unity\\relay\\relay_win.exe",
      "args": [
        "--mcp"
      ],
      "env": {
        "UNITY_PROJECT_PATH": "D:\\Projects\\project-twelve"
      }
    },
    "project-twelve-ingame-mcp": {
      "url": "http://127.0.0.1:8765/mcp",
      "type": "http"
    },
    "project-twelve-fff-mcp": {
      "type": "stdio",
      "command": "C:\\Users\\dmnsy\\AppData\\Local\\fff-mcp\\bin\\fff-mcp.exe",
      "args": ["--no-warmup", "D:\\Projects\\project-twelve"]
    }
  }
}

# ============================================
# Unity generated files and folders
# ============================================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Bb]uildPlayerData/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain sensitive data
[Mm]emoryCaptures/
[Pp]rofileData/
[Pp]rofilerLog/

# ============================================
# Asset meta data
# ============================================
# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta
!*.meta

# ============================================
# IDE and editor files
# ============================================
# Visual Studio cache directory
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# JetBrains Rider
.idea/
*.iml
*.sln.iml
[Aa]ssets/Plugins/Editor/JetBrains*

# Consulo cache
.consulo/

# ============================================
# Autogenerated project files
# ============================================
# Note: Unity regenerates .csproj and .sln files
*.csproj
*.sln
*.unityproj
*.suo
*.tmp
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.csproj.user

# Unity3D generated meta files (debug files)
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity upgrade and recovery files
UpgradeLog.htm
[Aa]ssets/_[Rr]ecovery/
_[Rr]ecovery/

# Exported project files
ExportedObj/

# ============================================
# Build outputs
# ============================================
*.apk
*.aab
*.ipa
*.app
*.unitypackage
*.appx
*.appxbundle
*.msix
*.msixbundle
*.exe
*.dmg
*.pkg

# ============================================
# Crash reports and diagnostics
# ============================================
sysinfo.txt
crashlytics-build.properties
*.crash
*.log

# ============================================
# Package manager and Addressables
# ============================================
# Packed Addressables (binary data - too large for git)
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.hash

# Package manager lock files (if using local packages)
[Pp]ackages/packages-lock.json

# ============================================
# Platform-specific build tools
# ============================================
# Gradle cache directory (Android)
.gradle/
gradle/
*.gradle
!build.gradle
!settings.gradle

# CocoaPods (iOS)
Pods/
*.xcworkspace

# ============================================
# Streaming assets (auto-generated)
# ============================================
# Temporary auto-generated Android Assets
[Aa]ssets/[Ss]treamingAssets/aa.meta
[Aa]ssets/[Ss]treamingAssets/aa/*

# ============================================
# Testing and coverage
# ============================================
[Tt]estResults/
[Cc]overage/
*.coverage
*.coveragexml

# ============================================
# OS-specific files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ============================================
# Optional: Uncomment if you wish to ignore the asset store tools plugin
# ============================================
# /[Aa]ssets/AssetStoreTools*
# ============================================
# Agent and local automation config
# ============================================
secrets.json
.env
.env.*
!.env.example
.claude/settings.local.json
.cursor/mcp.json
.agent/scratch/*
!.agent/scratch/.gitkeep
.agent-memory/raw-sessions/*
!.agent-memory/raw-sessions/.gitkeep
.agent-memory/dreams/*
!.agent-memory/dreams/.gitkeep
.agent-runs/

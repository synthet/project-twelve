# Cursor Ignore - Files and directories to exclude from AI indexing

# Unity build artifacts and temporary files
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Memory captures
[Mm]emoryCaptures/

# Visual Studio cache
.vs/

# JetBrains Rider cache
.idea/
*.iml

# Autogenerated files
*.unityproj
*.suo
*.tmp
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity meta files (keep Assets but ignore generated ones)
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Build outputs
*.apk
*.aab
*.unitypackage

# Crash reports
sysinfo.txt
crashlytics-build.properties

# Packed Addressables
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Gradle cache
.gradle/

# Consulo cache
.consulo/

# Exported objects
ExportedObj/


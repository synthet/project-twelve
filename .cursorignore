# Cursor Ignore - Files and directories to exclude from AI indexing
# This file prevents Cursor from indexing build artifacts, temporary files, and generated content

# ============================================
# Unity build artifacts and temporary files
# ============================================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Bb]uildPlayerData/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Pp]rojectSettings/ProjectVersion.txt
[Pp]rojectSettings/ProjectSettings.asset.backup

# Memory captures and profiling data
[Mm]emoryCaptures/
[Pp]rofileData/
[Pp]rofilerLog/

# ============================================
# IDE and editor caches
# ============================================
# Visual Studio / Visual Studio Code
.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# JetBrains Rider
.idea/
*.iml
*.sln.iml

# Consulo
.consulo/

# ============================================
# Autogenerated Unity files
# ============================================
*.unityproj
*.tmp
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.csproj.user

# Unity meta files (keep Assets/*.meta but ignore generated debug files)
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ============================================
# Build outputs and packages
# ============================================
*.apk
*.aab
*.ipa
*.app
*.unitypackage
*.appx
*.appxbundle
*.msix
*.msixbundle
*.exe
*.dmg
*.pkg

# ============================================
# Crash reports and diagnostics
# ============================================
sysinfo.txt
crashlytics-build.properties
*.crash
*.log

# ============================================
# Package manager and Addressables
# ============================================
# Packed Addressables (binary data)
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.hash

# Package manager cache (if using local packages)
[Pp]ackages/packages-lock.json

# ============================================
# Platform-specific build tools
# ============================================
# Gradle (Android)
.gradle/
gradle/
*.gradle
!build.gradle
!settings.gradle

# CocoaPods (iOS)
Pods/
*.xcworkspace

# ============================================
# Exported and generated project files
# ============================================
ExportedObj/
[Aa]ssets/Plugins/Editor/JetBrains*

# ============================================
# Streaming assets (auto-generated)
# ============================================
[Aa]ssets/[Ss]treamingAssets/aa.meta
[Aa]ssets/[Ss]treamingAssets/aa/*

# ============================================
# Testing and coverage
# ============================================
[Ll]ogs/
[Tt]estResults/
[Cc]overage/
*.coverage
*.coveragexml

# ============================================
# OS-specific files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

